# Copia este archivo a .env y rellena tus credenciales reales.
# NUNCA subas .env al repositorio.

SYLTEK_URL=https://tuclub.syltek.com
SYLTEK_USER=tu_usuario
SYLTEK_PASSWORD=tu_contraseña

# Configuración por defecto (opcional, también editable en la UI)
DRY_RUN=true
DEBUG_MODE=false
SCREENSHOTS_DIR=debug/screenshots
HTML_DUMP_DIR=debug/html
